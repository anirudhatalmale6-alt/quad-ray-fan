// https://mozilla.org/MPL/2.0/

//@version=5
indicator("Quad-Ray Fan", overlay=true, max_lines_count=4)

// ─────────────────────────────────────────────────────────────────────────────
//  ANCHOR POINTS — 2 clicks only (time + price captured per click)
//  The input.time and input.price pairs merge into a single click each.
// ─────────────────────────────────────────────────────────────────────────────

anchor1_time  = input.time(timestamp("2099-12-31"), "Anchor 1", confirm=true, inline="a1", group="Anchors")
anchor1_price = input.price(0.0, "", confirm=true, inline="a1", group="Anchors")
anchor2_time  = input.time(timestamp("2099-12-31"), "Anchor 2", confirm=true, inline="a2", group="Anchors")
anchor2_price = input.price(0.0, "", confirm=true, inline="a2", group="Anchors")

// ── Magnetic snap: locks to whichever wick end is nearest to click ─────────
snapOn = input.bool(true, "Magnetic snap to nearest wick", group="Anchors")

// ─────────────────────────────────────────────────────────────────────────────
//  SLOPE CONTROLS
// ─────────────────────────────────────────────────────────────────────────────

slope_NW = input.float(1.0, "NW Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_NE = input.float(1.0, "NE Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_SW = input.float(1.0, "SW Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_SE = input.float(1.0, "SE Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")

// ─────────────────────────────────────────────────────────────────────────────
//  RAY LENGTH
// ─────────────────────────────────────────────────────────────────────────────

rayLength = input.int(499, "Ray length (bars)", minval=10, maxval=499, step=10, group="Ray Length",
     tooltip="How many bars each ray extends. Max 499 (TradingView limit for future rays). Past rays are also capped here to keep them visible — increase if NW/SW rays disappear.")

// ─────────────────────────────────────────────────────────────────────────────
//  MIRROR TOGGLES
// ─────────────────────────────────────────────────────────────────────────────

mirror_h_NW_SW = input.bool(false, "Mirror NW / SW  (horizontal)", group="Mirror")
mirror_h_NE_SE = input.bool(false, "Mirror NE / SE  (horizontal)", group="Mirror")
mirror_v_NW_NE = input.bool(false, "Mirror NW / NE  (vertical)", group="Mirror")
mirror_v_SW_SE = input.bool(false, "Mirror SW / SE  (vertical)", group="Mirror")

// ─────────────────────────────────────────────────────────────────────────────
//  COLOUR INVERSION
//  When ON, colours auto-swap between "up" and "down" rays depending on
//  whether the setup is L→H (bullish) or H→L (bearish).
//  L→H (Anchor 1 below Anchor 2): normal colours
//  H→L (Anchor 1 above Anchor 2): NW↔SW colours swap, NE↔SE colours swap
// ─────────────────────────────────────────────────────────────────────────────

invertColors = input.bool(true, "Auto-invert colours for H→L setup", group="Colour Inversion",
     tooltip="When ON, the colour scheme automatically flips when Anchor 1 is above Anchor 2 (H→L). NW swaps with SW colours, NE swaps with SE colours.")

// ─────────────────────────────────────────────────────────────────────────────
//  RAY APPEARANCE — colour, width, style & visibility per ray
// ─────────────────────────────────────────────────────────────────────────────

show_NW  = input.bool(true, "Show NW Ray", group="NW Ray Style")
col_NW   = input.color(color.red,    "NW — Colour", group="NW Ray Style")
width_NW = input.int(2, "NW — Width", minval=1, maxval=10, group="NW Ray Style")
style_NW = input.string("Solid", "NW — Style", options=["Solid", "Dashed", "Dotted"], group="NW Ray Style")

show_NE  = input.bool(true, "Show NE Ray", group="NE Ray Style")
col_NE   = input.color(color.blue,   "NE — Colour", group="NE Ray Style")
width_NE = input.int(2, "NE — Width", minval=1, maxval=10, group="NE Ray Style")
style_NE = input.string("Solid", "NE — Style", options=["Solid", "Dashed", "Dotted"], group="NE Ray Style")

show_SW  = input.bool(true, "Show SW Ray", group="SW Ray Style")
col_SW   = input.color(color.green,  "SW — Colour", group="SW Ray Style")
width_SW = input.int(2, "SW — Width", minval=1, maxval=10, group="SW Ray Style")
style_SW = input.string("Solid", "SW — Style", options=["Solid", "Dashed", "Dotted"], group="SW Ray Style")

show_SE  = input.bool(true, "Show SE Ray", group="SE Ray Style")
col_SE   = input.color(color.orange, "SE — Colour", group="SE Ray Style")
width_SE = input.int(2, "SE — Width", minval=1, maxval=10, group="SE Ray Style")
style_SE = input.string("Solid", "SE — Style", options=["Solid", "Dashed", "Dotted"], group="SE Ray Style")

// ─────────────────────────────────────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────────────────────────────────────

lineStyle(s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

magSnap(float clickPrice, float h, float l) =>
    math.abs(clickPrice - h) <= math.abs(clickPrice - l) ? h : l

// ─────────────────────────────────────────────────────────────────────────────
//  FIND ANCHOR BARS — runs on every bar
// ─────────────────────────────────────────────────────────────────────────────

var int   idx1    = na
var int   idx2    = na
var float highAt1 = na
var float lowAt1  = na
var float highAt2 = na
var float lowAt2  = na

if time <= anchor1_time
    idx1    := bar_index
    highAt1 := high
    lowAt1  := low

if time <= anchor2_time
    idx2    := bar_index
    highAt2 := high
    lowAt2  := low

// ─────────────────────────────────────────────────────────────────────────────
//  DRAW RAYS
// ─────────────────────────────────────────────────────────────────────────────

var line rayNW = na
var line rayNE = na
var line raySW = na
var line raySE = na

if barstate.islast and not na(idx1) and not na(idx2)

    // ── Resolve anchor prices ────────────────────────────────────────────
    float p1 = snapOn ? magSnap(anchor1_price, highAt1, lowAt1) : anchor1_price
    float p2 = snapOn ? magSnap(anchor2_price, highAt2, lowAt2) : anchor2_price

    // ── Determine if setup is H→L (bearish) for colour inversion ────────
    //    Use raw click prices (before snap) so inversion always matches
    //    the user's click intent regardless of which wick gets snapped to.
    bool doInvert = invertColors and (anchor1_price > anchor2_price)

    // ── Base slope ─────────────────────────────────────────────────────
    float dBars     = math.max(math.abs(idx2 - idx1), 1)
    float dPrice    = math.abs(p2 - p1)
    float baseSlope = dPrice / dBars

    // ── Mirror logic ──────────────────────────────────────────────────
    float eff_NW = slope_NW
    float eff_NE = mirror_v_NW_NE ? slope_NW : slope_NE
    float eff_SW = mirror_h_NW_SW ? slope_NW : slope_SW
    float eff_SE = mirror_h_NE_SE ? (mirror_v_NW_NE ? slope_NW : slope_NE) : (mirror_v_SW_SE ? (mirror_h_NW_SW ? slope_NW : slope_SW) : slope_SE)

    // ── Ray endpoints ─────────────────────────────────────────────────
    int futureReach = rayLength
    int pastReach   = math.min(rayLength, math.max(idx1, 1))

    int   nw_x2 = idx1 - pastReach
    float nw_y2 = p1 + baseSlope * eff_NW * pastReach

    int   ne_x2 = idx1 + futureReach
    float ne_y2 = p1 + baseSlope * eff_NE * futureReach

    int   sw_x2 = idx1 - pastReach
    float sw_y2 = p1 - baseSlope * eff_SW * pastReach

    int   se_x2 = idx1 + futureReach
    float se_y2 = p1 - baseSlope * eff_SE * futureReach

    // ── Clean up old drawings ─────────────────────────────────────────
    line.delete(rayNW)
    line.delete(rayNE)
    line.delete(raySW)
    line.delete(raySE)

    // ── Draw rays ─────────────────────────────────────────────────────
    //    When doInvert: NW direction uses SW's appearance, and vice versa.
    //                   NE direction uses SE's appearance, and vice versa.
    //    This is done with explicit if/else to avoid Pine Script issues
    //    with conditional variable assignments.
    if doInvert
        // INVERTED (H→L): swap up/down appearance AND visibility
        if show_SW
            rayNW := line.new(idx1, p1, nw_x2, nw_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_SW, width=width_SW, style=lineStyle(style_SW))
        if show_SE
            rayNE := line.new(idx1, p1, ne_x2, ne_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_SE, width=width_SE, style=lineStyle(style_SE))
        if show_NW
            raySW := line.new(idx1, p1, sw_x2, sw_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_NW, width=width_NW, style=lineStyle(style_NW))
        if show_NE
            raySE := line.new(idx1, p1, se_x2, se_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_NE, width=width_NE, style=lineStyle(style_NE))
    else
        // NORMAL (L→H): standard appearance
        if show_NW
            rayNW := line.new(idx1, p1, nw_x2, nw_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_NW, width=width_NW, style=lineStyle(style_NW))
        if show_NE
            rayNE := line.new(idx1, p1, ne_x2, ne_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_NE, width=width_NE, style=lineStyle(style_NE))
        if show_SW
            raySW := line.new(idx1, p1, sw_x2, sw_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_SW, width=width_SW, style=lineStyle(style_SW))
        if show_SE
            raySE := line.new(idx1, p1, se_x2, se_y2, xloc=xloc.bar_index, extend=extend.none,
                 color=col_SE, width=width_SE, style=lineStyle(style_SE))


// ─────────────────────────────────────────────────────────────────────────────
//  USAGE
//  1. Add to chart → click twice (Anchor 1, then Anchor 2)
//  2. Magnetic snap locks to nearest wick (High or Low) based on click
//  3. Gear icon to adjust slopes, mirrors, colours
//  4. Auto-invert: colours swap when Anchor 1 is above Anchor 2 (H→L)
//  5. Show/hide individual rays with checkboxes in each ray's style group
// ─────────────────────────────────────────────────────────────────────────────
