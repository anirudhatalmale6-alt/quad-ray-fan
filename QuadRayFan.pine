// This Pine Script™ is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/

//@version=6
indicator("Quad-Ray Fan", overlay=true, max_lines_count=4)

// ─────────────────────────────────────────────────────────────────────────────
//  ANCHOR POINTS
//  Click on the chart to place each point when adding the indicator.
//  Anchor 1 = origin of all four rays.
//  Anchor 2 = sets the base slope (price-per-bar steepness).
// ─────────────────────────────────────────────────────────────────────────────

anchor1_time  = input.time(timestamp("2026-01-01T00:00:00"), "Anchor 1 — Time",  confirm=true, group="Anchor Points")
anchor1_price = input.price(0.0,                             "Anchor 1 — Price", confirm=true, group="Anchor Points")
anchor2_time  = input.time(timestamp("2026-01-02T00:00:00"), "Anchor 2 — Time",  confirm=true, group="Anchor Points")
anchor2_price = input.price(0.0,                             "Anchor 2 — Price", confirm=true, group="Anchor Points")

// ── Snap anchors to candle High or Low (wick tips) instead of click price ──
snap1 = input.string("Exact click", "Anchor 1 — Snap to", options=["Exact click", "High (wick top)", "Low (wick bottom)"], group="Anchor Points")
snap2 = input.string("Exact click", "Anchor 2 — Snap to", options=["Exact click", "High (wick top)", "Low (wick bottom)"], group="Anchor Points")

// ─────────────────────────────────────────────────────────────────────────────
//  SLOPE CONTROLS
//  Each value is a multiplier applied to the base slope derived from the two
//  anchor points.  1.0 = same steepness as the anchor-to-anchor line.
//  0.5 = half as steep, 2.0 = twice as steep, etc.
//  Sign is handled automatically per quadrant — just use positive numbers.
// ─────────────────────────────────────────────────────────────────────────────

slope_NW = input.float(1.0, "NW Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_NE = input.float(1.0, "NE Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_SW = input.float(1.0, "SW Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")
slope_SE = input.float(1.0, "SE Ray — Slope multiplier", minval=0.01, step=0.05, group="Slope")

// ─────────────────────────────────────────────────────────────────────────────
//  MIRROR TOGGLES
//
//  Horizontal mirror (around a horizontal line through Anchor 1):
//      NW ↔ SW : when enabled, SW copies NW's slope so both rays are
//                symmetric above/below the horizontal.
//      NE ↔ SE : when enabled, SE copies NE's slope.
//
//  Vertical mirror (around a vertical line through Anchor 1):
//      NW ↔ NE : when enabled, NE copies NW's slope so both rays are
//                symmetric left/right of the vertical.
//      SW ↔ SE : when enabled, SE copies SW's slope.
//
//  When a mirror is active the dependent ray ignores its own slope input.
// ─────────────────────────────────────────────────────────────────────────────

mirror_h_NW_SW = input.bool(false, "Mirror NW / SW  (horizontal — SW copies NW slope)", group="Mirror")
mirror_h_NE_SE = input.bool(false, "Mirror NE / SE  (horizontal — SE copies NE slope)", group="Mirror")
mirror_v_NW_NE = input.bool(false, "Mirror NW / NE  (vertical   — NE copies NW slope)", group="Mirror")
mirror_v_SW_SE = input.bool(false, "Mirror SW / SE  (vertical   — SE copies SW slope)", group="Mirror")

// ─────────────────────────────────────────────────────────────────────────────
//  RAY APPEARANCE — colour, width & style for each ray
// ─────────────────────────────────────────────────────────────────────────────

col_NW   = input.color(color.red,    "NW — Colour", group="NW Ray Style")
width_NW = input.int(2, "NW — Width", minval=1, maxval=10, group="NW Ray Style")
style_NW = input.string("Solid", "NW — Style", options=["Solid", "Dashed", "Dotted"], group="NW Ray Style")

col_NE   = input.color(color.blue,   "NE — Colour", group="NE Ray Style")
width_NE = input.int(2, "NE — Width", minval=1, maxval=10, group="NE Ray Style")
style_NE = input.string("Solid", "NE — Style", options=["Solid", "Dashed", "Dotted"], group="NE Ray Style")

col_SW   = input.color(color.green,  "SW — Colour", group="SW Ray Style")
width_SW = input.int(2, "SW — Width", minval=1, maxval=10, group="SW Ray Style")
style_SW = input.string("Solid", "SW — Style", options=["Solid", "Dashed", "Dotted"], group="SW Ray Style")

col_SE   = input.color(color.orange, "SE — Colour", group="SE Ray Style")
width_SE = input.int(2, "SE — Width", minval=1, maxval=10, group="SE Ray Style")
style_SE = input.string("Solid", "SE — Style", options=["Solid", "Dashed", "Dotted"], group="SE Ray Style")

// ─────────────────────────────────────────────────────────────────────────────
//  HELPER — convert style string → line.style_* constant
// ─────────────────────────────────────────────────────────────────────────────

lineStyle(s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

// ─────────────────────────────────────────────────────────────────────────────
//  FIND ANCHOR BAR INDICES + SNAPPED PRICES
//  These run on every bar to capture the correct bar_index and high/low.
// ─────────────────────────────────────────────────────────────────────────────

var int   idx1     = na
var int   idx2     = na
var float highAt1  = na
var float lowAt1   = na
var float highAt2  = na
var float lowAt2   = na

if time <= anchor1_time
    idx1    := bar_index
    highAt1 := high
    lowAt1  := low
if time <= anchor2_time
    idx2    := bar_index
    highAt2 := high
    lowAt2  := low

// ─────────────────────────────────────────────────────────────────────────────
//  DRAW RAYS — executes once on the last (real-time) bar
// ─────────────────────────────────────────────────────────────────────────────

var line rayNW = na
var line rayNE = na
var line raySW = na
var line raySE = na

if barstate.islast and not na(idx1) and not na(idx2)

    // ── Resolve snapped anchor prices ──────────────────────────────────
    float p1 = snap1 == "High (wick top)" ? highAt1 : snap1 == "Low (wick bottom)" ? lowAt1 : anchor1_price
    float p2 = snap2 == "High (wick top)" ? highAt2 : snap2 == "Low (wick bottom)" ? lowAt2 : anchor2_price

    // ── Base slope: price change per bar between the two anchors ────────
    float dBars     = math.max(math.abs(idx2 - idx1), 1)
    float dPrice    = math.abs(p2 - p1)
    float baseSlope = dPrice / dBars

    // ── Effective slope multipliers after mirror logic ──────────────────
    float eff_NW = slope_NW
    float eff_NE = mirror_v_NW_NE ? slope_NW : slope_NE
    float eff_SW = mirror_h_NW_SW ? slope_NW : slope_SW
    // SE can be driven by either mirror chain
    float eff_SE = mirror_h_NE_SE ? (mirror_v_NW_NE ? slope_NW : slope_NE) : (mirror_v_SW_SE ? (mirror_h_NW_SW ? slope_NW : slope_SW) : slope_SE)

    // ── Large reach so lines act as rays across the visible chart ──────
    int reach = 5000

    // ── Compute end points for each ray ────────────────────────────────
    //    NW = backward in time (left), upward in price
    //    NE = forward in time (right), upward in price
    //    SW = backward in time (left), downward in price
    //    SE = forward in time (right), downward in price

    int   nw_x2 = idx1 - reach
    float nw_y2 = p1 + baseSlope * eff_NW * reach

    int   ne_x2 = idx1 + reach
    float ne_y2 = p1 + baseSlope * eff_NE * reach

    int   sw_x2 = idx1 - reach
    float sw_y2 = p1 - baseSlope * eff_SW * reach

    int   se_x2 = idx1 + reach
    float se_y2 = p1 - baseSlope * eff_SE * reach

    // ── Delete previous lines to avoid duplicates on each tick ──────────
    line.delete(rayNW)
    line.delete(rayNE)
    line.delete(raySW)
    line.delete(raySE)

    // ── Draw the four rays (no extend — endpoints are far enough) ──────
    rayNW := line.new(idx1, p1, nw_x2, nw_y2, xloc=xloc.bar_index, extend=extend.none,
         color=col_NW, width=width_NW, style=lineStyle(style_NW))

    rayNE := line.new(idx1, p1, ne_x2, ne_y2, xloc=xloc.bar_index, extend=extend.none,
         color=col_NE, width=width_NE, style=lineStyle(style_NE))

    raySW := line.new(idx1, p1, sw_x2, sw_y2, xloc=xloc.bar_index, extend=extend.none,
         color=col_SW, width=width_SW, style=lineStyle(style_SW))

    raySE := line.new(idx1, p1, se_x2, se_y2, xloc=xloc.bar_index, extend=extend.none,
         color=col_SE, width=width_SE, style=lineStyle(style_SE))

// ─────────────────────────────────────────────────────────────────────────────
//  USAGE NOTES
//
//  1. Add the indicator to any chart (Indicators → Invite-only / My Scripts).
//  2. TradingView will immediately ask you to click TWICE on the chart:
//        First click  → Anchor 1 (ray origin)
//        Second click → Anchor 2 (sets base steepness)
//  3. All four rays appear instantly after the second click.
//  4. To snap an anchor to a candle's wick tip instead of the exact click
//     location, change "Anchor N — Snap to" to "High" or "Low" in settings.
//  5. To adjust settings later, click the gear icon on the indicator label
//     or double-click any ray.  Inputs are grouped into:
//        • Anchor Points — reposition origins + snap-to-wick option
//        • Slope         — fine-tune each ray's steepness
//        • Mirror        — toggle symmetry between ray pairs
//        • NW/NE/SW/SE Ray Style — colour, width, line style
//
// ─────────────────────────────────────────────────────────────────────────────
